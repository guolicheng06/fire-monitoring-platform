# =========================================
#   Vercel 部署环境变量配置示例
# =========================================
#
# 复制此文件为 .env.example，然后填写实际值
# 在 Vercel 项目设置中添加这些环境变量
#
# 访问 Vercel: https://vercel.com/dashboard
# → 项目 → Settings → Environment Variables
#
# =========================================

# ========== Supabase 配置 ==========
# 访问 https://supabase.com/dashboard
# → 项目 → Settings → API
# → 复制 Project URL 和 anon/public key

# 公开的 Supabase URL（前端可用）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# 公开的 Supabase Anon Key（前端可用）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 服务端使用的密钥（仅服务端可用，不要暴露到前端）
# 访问 https://supabase.com/dashboard
# → 项目 → Settings → API
# → 复制 service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========== 应用配置 ==========

# 应用名称
NEXT_PUBLIC_APP_NAME=消防智能监控平台

# API 超时时间（毫秒）
API_TIMEOUT_MS=30000

# ========== 设备连接配置（可选） ==========

# 瑶安云平台 API 地址（如果有）
YAK_AN_CLOUD_API_URL=https://api.yaoankj.com

# 瑶安云平台 API Key（如果有）
YAK_AN_CLOUD_API_KEY=your_api_key_here
